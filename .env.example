# Example environment file.
# Copy to `.env.local` for local development, or configure these same keys in
# your deploy provider's Environment Variables / Secrets settings.
#
# Examples:
# - Render: Dashboard > Service > Environment
# - Railway: Project > Variables
# - Fly.io: `fly secrets set KEY=value`
# - Docker Compose local: `docker compose --env-file .env.local up -d`

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local: use the docker-compose Postgres service below.
# Production/staging: replace DATABASE_URL with your managed Postgres URL.
POSTGRES_DB=scrapper_freelance
POSTGRES_USER=scrapper
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://scrapper:change-me@localhost:5432/scrapper_freelance
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

# ---------------------------------------------------------------------------
# API service
# ---------------------------------------------------------------------------
# Local API bind settings. Production platforms often inject PORT automatically.
APP_NAME=Scrapper Freelance API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ---------------------------------------------------------------------------
# AI email generation
# ---------------------------------------------------------------------------
# Keep this only in backend/API/worker environments. Never expose it to the
# Chrome extension, never prefix it with PLASMO_PUBLIC_, and never commit a real key.
OPENAI_API_KEY=sk-your-openai-api-key
AI_EMAIL_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# LinkedIn AI filters
# ---------------------------------------------------------------------------
# Optional post-capture job filters run only in backend/worker code. Do not add
# any AI provider secret or model variable with a PLASMO_PUBLIC_ prefix.
JOB_AI_FILTERS_ENABLED=false
JOB_AI_FILTER_MODEL_NAME=gpt-4o-mini

# ---------------------------------------------------------------------------
# Auth / user ownership
# ---------------------------------------------------------------------------
# Open self-signup is enabled for this MVP. Sessions are intended for browser
# session storage in the extension; the server TTL is a safety ceiling.
AUTH_SESSION_TTL_HOURS=12
AUTH_TOKEN_BYTES=32
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
DEFAULT_LOCAL_USER_EMAIL=local@example.com
DEFAULT_LOCAL_USER_DISPLAY_NAME=Local Operator

# ---------------------------------------------------------------------------
# Worker service
# ---------------------------------------------------------------------------
# Controls the background worker loop for LinkedIn processing and email sends.
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_RUN_ONCE=false
WORKER_MAX_RUNS_PER_LOOP=1
WORKER_MARK_STALE_RUNNING_ON_STARTUP=true

# ---------------------------------------------------------------------------
# LinkedIn authenticated browser collector
# ---------------------------------------------------------------------------
# Local only unless you deploy a host that can run a browser session.
# Keep logs out of git. In production, prefer disabling this collector or
# routing collection through a controlled operator machine.
LINKEDIN_BROWSER_COLLECTOR_SCRIPT_PATH=
LINKEDIN_BROWSER_COLLECTOR_API_BASE=http://localhost:8000
LINKEDIN_BROWSER_COLLECTOR_LOG_DIR=.local/linkedin-browser-collector-runs

# ---------------------------------------------------------------------------
# Resume storage
# ---------------------------------------------------------------------------
# Current implementation stores uploaded PDF bytes in PostgreSQL (`resume_attachments.file_content`).
# These vars remain as local/future storage adapter hints only; `.local/resumes` is not the source
# of truth for uploaded resumes. Future scalable option: add an `s3`, `r2`, or `gcs` adapter and
# store object keys in the DB while keeping metadata in PostgreSQL.
RESUME_STORAGE_BACKEND=local_fs
RESUME_STORAGE_DIR=.local/resumes

# ---------------------------------------------------------------------------
# Email provider
# ---------------------------------------------------------------------------
# v1 implementation uses Gmail API/OAuth, not SendGrid.
# Gmail API sends email through the operator's Gmail account after OAuth consent.
# It is a real email sending provider for this use case, with Gmail account
# limits and sender identity. For SaaS-style transactional email later, add a
# SendGrid/Resend/Postmark adapter behind EMAIL_PROVIDER.
EMAIL_PROVIDER=gmail
EMAIL_SEND_POLL_INTERVAL_SECONDS=5

# ---------------------------------------------------------------------------
# Gmail API/OAuth
# ---------------------------------------------------------------------------
# How to get these:
# 1. Google Cloud Console > create/select project.
# 2. Enable Gmail API.
# 3. Configure OAuth consent screen.
# 4. Credentials > Create OAuth client ID > Desktop app.
# 5. Download the JSON.
# 6. Local option: save it at GMAIL_OAUTH_CLIENT_SECRETS_FILE.
# 7. Deploy option: paste the raw JSON into GMAIL_OAUTH_CLIENT_CONFIG_JSON as an environment secret.
#
# The OAuth access/refresh token created after user consent is stored in PostgreSQL at
# `sending_provider_accounts.token_json`. The optional token file fallback exists only for local
# development/legacy manual flows and is not needed for Render-style deploys.
GMAIL_OAUTH_CLIENT_CONFIG_JSON=
GMAIL_OAUTH_CLIENT_SECRETS_FILE=.local/gmail/client_secret.json
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/sending/google-oauth/callback
GMAIL_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:8000/health

# ---------------------------------------------------------------------------
# Extension
# ---------------------------------------------------------------------------
# Local Plasmo extension API base. In another environment, point this to the
# deployed API URL.
PLASMO_PUBLIC_API_BASE_URL=http://localhost:8000
